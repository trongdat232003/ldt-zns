# KiotViet API
KIOTVIET_ACCESS_TOKEN=your_kiotviet_token_here
KIOTVIET_RETAILER=your_retailer_code_here

# ZNS API (YourSales)
ZNS_API_KEY=your_zns_api_key_here
ZNS_TEMPLATE_ID=499462

# Cấu hình thời gian
MINUTES_SINCE_PURCHASE=43200  # 30 ngày
MINUTES_BETWEEN_REMINDERS=36000  # 25 ngày
MAX_SEND_PER_RUN=50

# DRY RUN MODE (Test mode)
# true = không gửi tin thật, chỉ hiển thị
# false hoặc không set = gửi thật
DRY_RUN=true

# API Server (cho server.js)
API_SECRET=your_secret_key_for_api_auth_change_this
PORT=3456
