# KiotViet API
KIOTVIET_ACCESS_TOKEN=your_kiotviet_token_here
KIOTVIET_RETAILER=your_retailer_code_here

# ZNS API (YourSales)
ZNS_API_KEY=your_zns_api_key_here
ZNS_TEMPLATE_ID=499462

# Cấu hình thời gian (NGÀY - đơn giản hơn)
DAYS_SINCE_PURCHASE=30              # Nhắc sau 30 ngày từ lần mua
DAYS_BETWEEN_REMINDERS=25           # Không gửi lại trong vòng 25 ngày
MAX_SEND_PER_RUN=50                 # Giới hạn số tin mỗi lần chạy

# Incremental Sync - CHỈ LẤY HÓA ĐƠN MỚI
USE_INCREMENTAL_SYNC=true           # true = chỉ lấy mới (nhanh), false = lấy từ SYNC_FROM_DATE
SYNC_FROM_DATE=2026-07-01           # Fallback nếu USE_INCREMENTAL_SYNC=false

# DRY RUN MODE - Test với dữ liệu thật NHƯNG không gửi ZNS
# true = test mode (không gửi), false = production (gửi thật)
DRY_RUN=true

# API Server (cho n8n hoặc external trigger)
API_SECRET=your_secret_key_for_api_auth_change_this
PORT=3456

# Supabase Database
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=your-anon-key-here
